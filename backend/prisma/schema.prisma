// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Lightweight user/supporter identity (no auth, just a label for filtering and display).
// `role` distinguishes end-user submitters from internal supporters/agents.
model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  role      String   @default("user") // user | supporter

  // Tickets the user submitted (role=user)
  tickets         Ticket[] @relation("UserSubmittedTickets")
  // Tickets assigned to this user for handling (role=supporter)
  assignedTickets Ticket[] @relation("UserAssignedTickets")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// Ticket work item
model Ticket {
  id              String   @id @default(cuid())
  content         String   @db.Text
  status          String   @default("pending") // pending, processing, completed, failed, review, dlq
  priority        String   @default("medium") // low, medium, high

  // Submitting user (nullable for backwards compatibility with legacy rows).
  userId          String?
  user            User?    @relation("UserSubmittedTickets", fields: [userId], references: [id])

  // Assigned supporter (nullable). When set, this ticket appears in that
  // supporter's "My Tickets" view. Setting is null on user delete to avoid
  // dangling references — handled at app level since SetNull on optional
  // relation is the Prisma default for nullable foreign keys.
  assigneeId      String?
  assignee        User?    @relation("UserAssignedTickets", fields: [assigneeId], references: [id])

  // AI-generated content
  analysis        Json?
  suggestion      String?  @db.Text
  
  // Safety metadata
  confidence      Float?
  hallucination   Float?
  requiresReview  Boolean  @default(false)
  
  // Human approval
  approvalStatus  String? // pending, approved, rejected, edited
  edits           String?  @db.Text
  approvedBy      String?
  approvedAt      DateTime?
  
  logs            TicketLog[]
  tokenUsage      TokenUsage[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([assigneeId])
}

// TicketLog audit trail
model TicketLog {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  agentName   String   // analyzer, searcher, generator, approval
  toolName    String?
  actionType  String   // execute, success, error, retry
  
  input       Json?
  output      Json?
  error       String?  @db.Text
  
  duration    Int      // milliseconds
  timestamp   DateTime @default(now())
  metadata    Json?

  @@index([ticketId])
  @@index([timestamp])
}

// TokenUsage tracking
model TokenUsage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  model       String   // claude-3-5-sonnet-20241022
  inputTokens Int
  outputTokens Int
  cost        Float    // USD
  
  timestamp   DateTime @default(now())

  @@index([ticketId])
  @@index([timestamp])
}

// Document knowledge base entry
model Document {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  embedding   String?  @db.Text // vector JSON string
  source      String?
  similarity  Float?
  
  createdAt   DateTime @default(now())

  @@index([title])
}

// FAQEmbedding stores per-FAQ vector embeddings used by the L1 vector
// matcher. The faqId is the stable id from FAQ_DATABASE (e.g. "billing_003").
// `contentHash` is a digest of the source text we embedded, so we can
// detect when the FAQ was edited and re-embed only the changed rows on
// startup. Vector itself is JSON-serialized to keep the schema portable
// (the FAQ corpus is small enough that we don't need pgvector yet).
model FAQEmbedding {
  faqId       String   @id
  vector      String   @db.Text // JSON-serialized number[] (768 dims)
  contentHash String   // sha256(text passed to embed())
  model       String   // e.g. "text-embedding-004" - lets us re-embed when model changes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([model])
}

// DocumentEmbedding stores per-Document vector embeddings used by the
// L3 SearcherAgent (via SearchTool). docId is Document.id. Mirrors
// FAQEmbedding so the SearchTool can do real semantic retrieval against
// the KB instead of the previous local hash pseudo-embedding.
//
// `contentHash` is a digest of (title + content) we embedded, so we can
// detect content drift and re-embed only the rows that changed.
// `model` lets us re-embed every row when we swap embedding models.
model DocumentEmbedding {
  docId       String   @id
  vector      String   @db.Text // JSON-serialized number[] (768 dims)
  contentHash String
  model       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([model])
}

// ApprovalTask human approval task
model ApprovalTask {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  
  suggestion  String   @db.Text
  confidence  Float
  reasoning   String?  @db.Text
  
  status      String   @default("pending") // pending, approved, rejected, edited
  userDecision String?
  userMods    String?  @db.Text
  
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([status])
}
